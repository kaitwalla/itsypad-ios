    "clipboard.clear_alert.message_local" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden alle Zwischenablage-Einträge auf diesem Gerät entfernt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "This will remove all clipboard entries on this device."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto eliminará todas las entradas del portapapeles en este dispositivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprimera toutes les entrées du presse-papiers sur cet appareil."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verranno rimosse tutte le voci degli appunti su questo dispositivo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このデバイスのクリップボード履歴がすべて削除されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 기기의 모든 클립보드 항목이 제거됩니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spowoduje to usunięcie wszystkich wpisów schowka na tym urządzeniu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isso removerá todas as entradas da área de transferência neste dispositivo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Все записи буфера обмена на этом устройстве будут удалены."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这将移除此设备上的所有剪贴板条目。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這將移除此裝置上的所有剪貼簿項目。"
          }
        }
      }
    },
